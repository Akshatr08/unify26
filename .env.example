# ─── Required ─────────────────────────────────────────────────────────────────
# Powers every GenAI feature: copilot chat, incident classifier, translator,
# wayfinding, and ops brief generation.
# Get one free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Optional: Google APIs (see README § API Keys) ───────────────────────────

# Maps JavaScript API (browser-safe — must be prefixed VITE_)
# Upgrade: Replace static heatmap with live interactive stadium/host-city map.
VITE_GOOGLE_MAPS_KEY=

# Directions API (server-side)
# Upgrade: Real accessible walking directions from parking to gates.
GOOGLE_DIRECTIONS_KEY=

# Places API v2 (server-side)
# Upgrade: Nearby halal food, pharmacies, ATMs around the venue.
GOOGLE_PLACES_KEY=

# Cloud Translation API (server-side)
# Upgrade: Deterministic fallback for the 7-language radio translator.
GOOGLE_TRANSLATE_KEY=

# Cloud Text-to-Speech API (server-side)
# Upgrade: Broadcast translated PA announcements as audio.
GOOGLE_TTS_KEY=

# Cloud Speech-to-Text API (server-side)
# Upgrade: Voice incident reporting from staff radios.
GOOGLE_STT_KEY=

# Routes API (server-side)
# Upgrade: Real ETAs for shuttle/transit from user location to venue.
GOOGLE_ROUTES_KEY=
